generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model ProjectSubmission {
  id          String   @id @default(cuid())
  title       String
  type        String
  genre       String
  videoUrl    String
  thumbnailUrl String?
  description String
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}